  11   1        ES = 1;             // 允许串口中断
  12   1      }
  13          
  14          void Uart_Sendstring(unsigned char *pucStr)//0代表可收发，1代表收发完成
  15          {
  16   1        while(*pucStr != '\0')
  17   1        {
  18   2          SBUF = *pucStr;
  19   2          while(TI == 0);
  20   2          TI = 0;
  21   2          pucStr++;
  22   2        }
  23   1      }



   3          void UartInit(void)         //4800bps@12.000MHz
   4          { 
   5   1        SCON = 0x50;            // 8位数据,可变波特率
   6   1        AUXR |= 0x01;           // 串口1选择定时器2为波特率发生器
   7   1        AUXR |= 0x04;           // 定时器2时钟为Fosc, 即1T
   8   1        T2L = 0x8F;           // 设定定时初值
   9   1        T2H = 0xFD;             // 设定定时初值

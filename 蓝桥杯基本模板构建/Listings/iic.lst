 141          void EEPROM_Read(unsigned char* pucBuf, unsigned char addr, unsigned char num)
 142          {
 143   1          IIC_Start();
 144   1          IIC_SendByte(0xa0);
 145   1          IIC_WaitAck();
 146   1      

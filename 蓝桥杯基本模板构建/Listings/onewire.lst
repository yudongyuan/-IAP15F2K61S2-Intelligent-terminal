   1          /*
   2            程序说明: 单总线驱动程序
   3            软件环境: Keil uVision 4.10 
   4            硬件环境: CT107单片机综合实训平台(外部晶振12MHz) STC89C52RC单片机
   5            日    期: 2011-8-9
   6          */
   7          //#include <STC15F2K60S2.H> 严重错误。这里只要涉及到温度都必须使用reg52.h
   8          //因为该工程是在STC89C52RC单片机下调试出来的 若使用15f将无法读取
   9          #include "reg52.h"
  10          sbit DQ = P1^4;  //单总线接口 注意这个定义一定要放在c文件中不能放在头文件
  11          
  12          //单总线延时函数
  13          void Delay_OneWire(unsigned int t)  //STC89C52RC
  14          {
  15   1        unsigned char i;
  16   1        while(t--){
  17   2          for(i=0;i<12;i++);
  18   2        }
  19   1      }
  20          
  21          //通过单总线向DS18B20写一个字节
  22          void Write_DS18B20(unsigned char dat)
  23          {
  24   1        unsigned char i;
  25   1        for(i=0;i<8;i++)
  26   1        {
  27   2          DQ = 0;
  28   2          DQ = dat&0x01;
  29   2          Delay_OneWire(5);
  30   2          DQ = 1;
  31   2          dat >>= 1;
  32   2        }
  33   1        Delay_OneWire(5);
  34   1      }
  35          
  36          //从DS18B20读取一个字节
  37          unsigned char Read_DS18B20(void)
  38          {
  39   1        unsigned char i;
  40   1        unsigned char dat;
  41   1        
  42   1        for(i=0;i<8;i++)
  43   1        {
  44   2          DQ = 0;
  45   2          dat >>= 1;
  46   2          DQ = 1;
  47   2          if(DQ)
  48   2          {
  49   3            dat |= 0x80;
  50   3          }     
  51   2          Delay_OneWire(5);
  52   2        }
  53   1        return dat;
  54   1      }
C51 COMPILER V9.55   ONEWIRE                                                               04/02/2023 16:18:54 PAGE 2   

  55          
  56          //DS18B20设备初始化
  57          bit init_ds18b20(void)
  58          {
  59   1          bit initflag = 0;
  60   1          
  61   1          DQ = 1;
  62   1          Delay_OneWire(12);
  63   1          DQ = 0;
  64   1          Delay_OneWire(80);
  65   1          DQ = 1;
  66   1          Delay_OneWire(10); 
  67   1          initflag = DQ;     
  68   1          Delay_OneWire(5);
  69   1        
  70   1          return initflag;
  71   1      }
  72          
  73          unsigned int rd_temperature(void)
  74          {
  75   1        unsigned char low, high;
  76   1      
  77   1        init_ds18b20();         // 初始化
  78   1        Write_DS18B20(0xCC);        // 跳过ROM
  79   1        Write_DS18B20(0x44);        // 转换温度
  80   1       
  81   1        init_ds18b20();
  82   1        Write_DS18B20(0xCC);
  83   1        Write_DS18B20(0xBE);        // 读暂存器
  84   1        low = Read_DS18B20();       // 低字节
  85   1        high = Read_DS18B20();      // 高字节
  86   1      
  87   1        return (high<<8)+low;
  88   1      }



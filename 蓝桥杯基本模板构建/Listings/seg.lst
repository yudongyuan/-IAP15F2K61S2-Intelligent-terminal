   3          void Seg_Tran(unsigned char *Seg_Buf,unsigned char *Seg_Code)
   4          {
   5   1        unsigned char i,j=0,temp;
   6   1        for(i=0;i<8;i++,j++)
   7   1        {
   8   2          switch(Seg_Buf[j])//这个地方是j不是i，因为j代表字符串的位置，i是转换好的码，所以前面都是j最后是i
   9   2          {

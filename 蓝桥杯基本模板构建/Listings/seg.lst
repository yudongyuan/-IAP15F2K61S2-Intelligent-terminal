  18   3            case '8': temp=0x80; break;
  19   3            case '9': temp=0x90; break;
  20   3            case '-': temp=0xbf; break;
  21   3            case ' ': temp=0xff; break;
  22   3            default: temp=0xff;//注意是0xff
  23   3          }
  24   2          if(Seg_Buf[j+1]=='.')
